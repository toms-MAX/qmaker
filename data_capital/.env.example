# DATA CAPITAL 환경변수 템플릿
# 이 파일을 복사하여 .env 로 저장하고 실제 값을 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요.

# Firebase 자격증명 (serviceAccount.json 내용을 한 줄 JSON으로)
# python -c "import json; print(json.dumps(json.load(open('serviceAccount.json'))))"
FIREBASE_CREDENTIALS=

# 대시보드 접근 토큰 (비워두면 인증 없이 누구나 접근 가능)
# 예: DASHBOARD_TOKEN=my_secret_token_1234
DASHBOARD_TOKEN=

# 운영 모드 (paper / live)
TRADING_MODE=paper
